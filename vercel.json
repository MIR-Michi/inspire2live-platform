{
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build",
  "crons": [
    {
      "path": "/api/comms/digest",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/comms/conferences",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/comms/newsfeed",
      "schedule": "0 6 * * *"
    }
  ]
}
